generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  primaryColor String      @default("#f97316")
  logoUrl      String?
  faviconUrl   String?
  favTitle     String?
  customDomain String?     @unique
  authTitle       String?
  authDescription String?
  loginTitle      String?     @default("Tekrar Hoş Geldiniz!")
  loginSubtitle   String?     @default("Lütfen hesabınıza giriş yapmak için bilgilerinizi girin.")
  registerTitle   String?     @default("Aramıza Katılın!")
  registerSubtitle String?    @default("Yeni bir hesap oluşturarak aramıza katılın.")
  authImageUrl     String?
  fontFamily       String?     @default("Inter")
  defaultTheme     String?     @default("light")
  supportEmail     String?
  supportPhone     String?
  whatsappNumber   String?
  // Landing Page Content
  heroBadge        String?
  heroTitle        String?
  heroDescription  String?
  heroCta          String?
  heroSecondaryCta String?
  heroFeatures     String?
  featuresTitle    String?
  featuresSubtitle String?
  ctaTitle         String?
  ctaDescription   String?
  ctaButtonText    String?
  ownerId         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  classrooms   Classroom[]
  courses      Course[]
  projects     Project[]
  students     Student[]
  users        User[]
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  password               String
  name                   String?
  role                   Role                    @default(TEACHER)
  tier                   SubscriptionTier        @default(RESTRICTED)
  isActive               Boolean                 @default(true)
  passwordChangeRequired Boolean                 @default(false)
  resetToken             String?                 @unique
  resetTokenExpires      DateTime?
  subscriptionStarted    DateTime?
  subscriptionExpires    DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  hasCoachingAccess      Boolean                 @default(false)
  dailyAiLimit           Int                     @default(0)
  phone                  String?
  deviceTokens           String[]                @default([])
  organizationId         String?
  aiUsages               AiUsage[]
  classrooms             Classroom[]             @relation("TeacherClassrooms")
  coachingHistory        CoachingHistory[]
  courses                Course[]
  liveKitConfig          LiveKitConfig?
  liveSessions           LiveSession[]
  notifications          Notification[]
  sentBroadcasts         NotificationBroadcast[] @relation("SentBroadcasts")
  projects               Project[]
  projectFolders         ProjectFolder[]
  refreshTokens          RefreshToken[]
  students               Student[]               @relation("TeacherStudents")
  studentProfile         Student?
  assignedQuestions      StudentQuestion[]
  organization           Organization?           @relation(fields: [organizationId], references: [id])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  date      String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model ProjectFolder {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#f97316")
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id             String             @id @default(cuid())
  name           String
  userId         String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  folderId       String?
  category       ProjectCategory    @default(SB)
  organizationId String?
  assignments    Assignment[]
  attachments    CourseAttachment[]
  courseContents CourseContent[]
  folder         ProjectFolder?     @relation(fields: [folderId], references: [id])
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      Question[]
  settings       Settings?
}

model Question {
  id            String   @id @default(cuid())
  projectId     String
  imageUrl      String
  order         Int
  width         Float
  height        Float
  bottomSpacing Int      @default(0)
  difficulty    Int?
  correctAnswer String?
  createdAt     DateTime @default(now())
  isInformation Boolean  @default(false)
  infoType      String?
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Settings {
  id              String   @id @default(cuid())
  projectId       String   @unique
  title           String?
  subtitle        String?
  schoolName      String?
  colCount        Int      @default(2)
  questionSpacing Int      @default(10)
  watermarkText   String?
  showDebug       Boolean  @default(false)
  primaryColor    String   @default("#f97316")
  fontFamily      String   @default("Roboto")
  showDifficulty  Boolean  @default(false)
  showAnswerKey   Boolean  @default(false)
  qrCodeUrl       String?
  template        String   @default("classic")
  showCoverPage   Boolean  @default(false)
  coverTitle      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  displayMode     String   @default("normal")
  showOpticalForm Boolean  @default(false)
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id                        String                   @id @default(cuid())
  teacherId                 String
  userId                    String?                  @unique
  name                      String
  email                     String?
  phone                     String?
  gradeLevel                String?
  notes                     String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  dailyQuestionLimit        Int                      @default(0)
  parentPhone               String?
  classroomId               String?
  organizationId            String?
  assignments               Assignment[]
  contentProgress           ContentProgress[]
  enrollments               CourseEnrollment[]
  focusSessions             FocusSession[]
  liveSessionParticipations LiveSessionParticipant[]
  schedules                 Schedule[]
  classroom                 Classroom?               @relation(fields: [classroomId], references: [id])
  organization              Organization?            @relation(fields: [organizationId], references: [id])
  teacher                   User                     @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  user                      User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions                 StudentQuestion[]
}

model FocusSession {
  id                String      @id @default(cuid())
  studentId         String
  subject           String
  duration          Int
  actualTime        Int         @default(0)
  breakTime         Int         @default(0)
  status            FocusStatus @default(IN_PROGRESS)
  startTime         DateTime    @default(now())
  endTime           DateTime?
  interruptionCount Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Assignment {
  id                 String           @id @default(cuid())
  studentId          String
  title              String
  description        String?
  type               AssignmentType   @default(CUSTOM)
  status             AssignmentStatus @default(PENDING)
  projectId          String?
  externalUrl        String?
  dueDate            DateTime?
  duration           Int?             @default(0)
  allowedAttempts    Int              @default(1)
  attemptCount       Int              @default(0)
  completedAt        DateTime?
  grade              Float?
  answers            Json?
  feedback           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contentId          String?
  correctCount       Int?
  incorrectCount     Int?
  aiAnalysis         String?
  isArchivedFromPool Boolean          @default(false)
  content            CourseContent?   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  project            Project?         @relation(fields: [projectId], references: [id])
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Schedule {
  id          String         @id @default(cuid())
  studentId   String
  date        DateTime?
  dayOfWeek   Int?
  startTime   String?
  endTime     String?
  activity    String
  isCompleted Boolean        @default(false)
  courseId    String?
  contentId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isAllDay    Boolean        @default(false)
  note        String?
  subject     String?
  content     CourseContent? @relation(fields: [contentId], references: [id], onDelete: Cascade)
  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Course {
  id             String             @id @default(cuid())
  title          String
  description    String?
  thumbnailUrl   String?
  instructorId   String
  isPublished    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organizationId String?
  instructor     User               @relation(fields: [instructorId], references: [id])
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  enrollments    CourseEnrollment[]
  modules        CourseModule[]
}

model CourseModule {
  id        String          @id @default(cuid())
  courseId  String
  title     String
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  contents  CourseContent[]
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseContent {
  id           String             @id @default(cuid())
  moduleId     String
  title        String
  type         ContentType
  order        Int                @default(0)
  url          String?
  projectId    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  attemptLimit Int?               @default(0)
  duration     Int?               @default(0)
  assignments  Assignment[]
  progress     ContentProgress[]
  attachments  CourseAttachment[]
  module       CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  project      Project?           @relation(fields: [projectId], references: [id])
  schedules    Schedule[]
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseId    String
  studentId   String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model ContentProgress {
  id        String         @id @default(cuid())
  contentId String
  studentId String
  status    ProgressStatus @default(NOT_STARTED)
  updatedAt DateTime       @updatedAt
  content   CourseContent  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([contentId, studentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationBroadcast {
  id            String          @id @default(cuid())
  senderId      String
  title         String
  message       String
  link          String?
  targetUserIds String[]
  scheduledFor  DateTime?
  status        BroadcastStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sender        User            @relation("SentBroadcasts", fields: [senderId], references: [id], onDelete: Cascade)
}

model CoachingHistory {
  id           String   @id @default(cuid())
  userId       String
  query        String
  response     String
  createdAt    DateTime @default(now())
  action       String?
  assignmentId String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assignmentId])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiUsageLog {
  id               String   @id @default(cuid())
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  action           String?
  userId           String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model StudentQuestion {
  id         String         @id @default(cuid())
  studentId  String
  teacherId  String?
  lesson     String
  imageUrl   String
  status     QuestionStatus @default(PENDING)
  answerUrl  String?
  answerText String?
  answeredAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  isDeleted  Boolean        @default(false)
  student    Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    User?          @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
}

model Classroom {
  id             String        @id @default(cuid())
  name           String
  description    String?
  teacherId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  teacher        User          @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  liveSessions   LiveSession[]
  students       Student[]

  @@index([teacherId])
}

model LiveSession {
  id              String                   @id @default(cuid())
  teacherId       String
  classroomId     String?
  title           String
  roomName        String                   @unique
  status          LiveSessionStatus        @default(SCHEDULED)
  maxParticipants Int                      @default(10)
  maxDuration     Int                      @default(60)
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  egressId        String?
  recordingKey    String?
  downloadCount   Int                      @default(0)
  viewCount       Int                      @default(0)
  classroom       Classroom?               @relation(fields: [classroomId], references: [id])
  teacher         User                     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  participants    LiveSessionParticipant[]

  @@index([teacherId])
  @@index([classroomId])
  @@index([status])
}

model LiveSessionParticipant {
  id        String      @id @default(cuid())
  sessionId String
  studentId String
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  duration  Int         @default(0)
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
}

model LiveKitConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  apiKey      String
  apiSecret   String
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  s3AccessKey String?
  s3Bucket    String?
  s3Endpoint  String?
  s3SecretKey String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseAttachment {
  id        String        @id @default(cuid())
  contentId String
  title     String?
  projectId String?
  url       String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  content   CourseContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  project   Project?      @relation(fields: [projectId], references: [id])

  @@index([contentId])
  @@index([projectId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum SubscriptionTier {
  FREE
  BRONZ
  GUMUS
  ALTIN
  RESTRICTED
}

enum ProjectCategory {
  SB
  FA
}

enum FocusStatus {
  IN_PROGRESS
  COMPLETED
  INTERRUPTED
  CANCELLED
}

enum AssignmentType {
  TEST
  VIDEO
  READING
  CUSTOM
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ContentType {
  VIDEO
  PDF
  TEST
  TEXT
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum BroadcastStatus {
  PENDING
  SENT
  SCHEDULED
  FAILED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ASSIGNMENT_CREATED
  SCHEDULE_UPDATED
  COACHING_NOTE
  QUESTION_ASKED
  QUESTION_ANSWERED
}

enum QuestionStatus {
  PENDING
  ANSWERED
  REJECTED
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}
